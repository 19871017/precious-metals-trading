# ============================================
# 环境变量配置文件
# ============================================
# ⚠️ 警告：此文件包含敏感信息，请勿提交到版本控制系统
# 请确保 .env 已添加到 .gitignore

# GEMINI AI 配置
# 请在 https://makersuite.google.com/app/apikey 获取您的 API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 后端服务配置
VITE_API_BASE_URL=http://localhost:3001

# Finnhub 金融新闻 API 配置
# 请在 https://finnhub.io/register 注册免费账号获取 API Key
# 免费版限制：60次请求/分钟，足够个人使用
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here
