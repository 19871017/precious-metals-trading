# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=precious_metals_trading
DB_USER=postgres
DB_PASSWORD=your_password

# 日志数据库配置（可选）
DB_LOGS_NAME=precious_metals_trading_logs

# 数海API配置 (请替换为实际账号)
SHUHAI_USERNAME=your_shuhai_username
SHUHAI_PASSWORD=your_shuhai_password

# 服务器配置
PORT=3001
NODE_ENV=development

# CORS白名单 (生产环境必须设置)
# 多个域名用逗号分隔，如：https://example.com,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# 客户端地址 (用于 WebSocket CORS)
CLIENT_URL=http://localhost:5173

# JWT密钥 (生产环境必须设置为64字符以上的随机字符串)
# 请使用以下命令生成新的密钥: openssl rand -base64 64
JWT_SECRET=UoLYxvQRkV2ka2CGv/yTx/TSV5W0Rt3p8fSrX7e1TL3Gmv9MS9ndqt1EHSylSU5iONvkI4+tHDYMKN5rNFYkhw==

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
