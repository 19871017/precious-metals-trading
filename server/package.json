{
  "name": "precious-metals-trading-server",
  "version": "1.0.0",
  "description": "贵金属期货交易系统后端服务",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/index.ts",
    "dev:watch": "npx tsx watch src/index.ts",
    "dev:simple": "node --import tsx/esm src/index-simple.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "db:migrate": "node --import tsx/esm src/scripts/migrate.ts",
    "db:seed": "node --import tsx/esm src/scripts/seed.ts",
    "db:init-shuhai": "node --import tsx/esm src/scripts/init-shuhai-cache.ts",
    "docs": "jsdoc2md src -c jsdoc.json -t node_modules/tsd-jsdoc/dist -r"
  },
  "keywords": [
    "trading",
    "forex",
    "precious-metals",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.4.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "pm2": "^5.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
